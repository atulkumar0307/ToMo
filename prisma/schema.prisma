generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OtpAction {
  LOGIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivityCategory {
  COFFEE
  WALKING
  SPORTS
  GYM
  STUDY
  COWORKING
  DINING
  TRAVEL
  ENTERTAINMENT
  OTHER
}

enum ActivityStatus {
  PUBLISHED
  DELETED
  CANCELLED
  ACTIVE
  COMPLETED
  EXPIRED
}

enum ParticipantStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
  EXPIRED
}

model Counter {
  id    String @id
  value Int    @default(0)
}

model User {
  id                 String         @id @default(uuid())
  uid                Int            @unique
  mobile             String         @unique
  isBlocked          Boolean        @default(false)
  fullName           String?
  profileImagePath   String?
  gender             Gender?
  dateOfBirth        DateTime?      @db.Date
  bio                String?
  isProfileCompleted        Boolean        @default(false)
  isProfileVerified         Boolean        @default(false)
  fullNameUpdatedAt         DateTime?
  dateOfBirthUpdatedAt      DateTime?
  createdAt                 DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  refreshTokens         RefreshToken[]
  verificationSubmissions VerificationSubmission[]
  hostedActivities      Activity[]            @relation("HostedActivities")
  activityParticipants  ActivityParticipant[]

  @@index([mobile])
}

model Activity {
  id              String           @id @default(uuid())
  aid             Int              @unique
  hostId          String
  title           String
  description     String
  category        ActivityCategory
  locationName    String
  address         String?
  city            String?
  latitude        Float
  longitude       Float
  startTime       DateTime
  endTime         DateTime
  maxParticipants Int
  status          ActivityStatus   @default(PUBLISHED)
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  deletedAt       DateTime?
  expiredAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  host            User             @relation("HostedActivities", fields: [hostId], references: [id], onDelete: Cascade)
  participants    ActivityParticipant[]

  @@index([hostId])
  @@index([aid])
  @@index([status, startTime])
  @@index([category])
  @@index([city])
}

model ActivityParticipant {
  id         String            @id @default(uuid())
  activityId String
  userId     String
  status     ParticipantStatus @default(PENDING)
  isHost     Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  activity   Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([activityId, status])
  @@index([userId])
}

model VerificationSubmission {
  id        String               @id @default(uuid())
  userId    String
  status    VerificationStatus   @default(PENDING)
  remark    String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  images    VerificationImage[]

  @@index([userId])
  @@index([userId, status])
  @@index([status])
}

model VerificationImage {
  id           String                 @id @default(uuid())
  submissionId String
  imagePath    String
  sortOrder    Int
  createdAt    DateTime               @default(now())
  submission   VerificationSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model Otp {
  id        String    @id @default(uuid())
  mobile    String
  otp       String
  action    OtpAction
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([mobile, action, isUsed, expiresAt])
  @@index([mobile, createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Admin {
  id            String              @id @default(uuid())
  email         String              @unique
  passwordHash  String
  fullName      String
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  refreshTokens AdminRefreshToken[]

  @@index([email])
}

model AdminRefreshToken {
  id        String   @id @default(uuid())
  adminId   String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([token])
  @@index([expiresAt])
}
