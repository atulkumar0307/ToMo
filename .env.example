NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://user:password@localhost:5432/tomo_db?schema=public"

JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

JWT_ADMIN_ACCESS_SECRET=your-admin-access-secret-change-in-production
JWT_ADMIN_REFRESH_SECRET=your-admin-refresh-secret-change-in-production
JWT_ADMIN_ACCESS_EXPIRES_IN=15m
JWT_ADMIN_REFRESH_EXPIRES_IN=7d

OTP_EXPIRY_MINUTES=10
DEV_OTP=000000
